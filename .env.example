OPENAI_API_KEY=
GEMINI_API_KEY=
NEXT_PUBLIC_A2A_ORCHESTRATION_BASE_URL=
AINSPACE_STORAGE_REDIS_URL=
AINSPACE_BLOB_READ_WRITE_TOKEN=

ADMIN_DASHBOARD_URL= # for cors header
ADMIN_API_SECRET= # shared secret for admin dashboard API bypass

# Agent movement settings
# Radius for spawn-centered movement mode (in tiles, default: 3)
NEXT_PUBLIC_SPAWN_RADIUS=3

# Report API (optional, falls back to NEXT_PUBLIC_A2A_ORCHESTRATION_BASE_URL)
DEMO_REPORT_URL=

# New backend (NestJS JWT auth) — server-only, called by BFF (not exposed to browser)
# Empty = backend auth disabled (BFF /api/backend-auth/* returns 503)
BACKEND_BASE_URL=
BACKEND_CLIENT_ID=ainspace
# Browser-DIRECT auth (verify/refresh) needs the backend origin + client id in the
# browser bundle (cookie-based refresh; httpOnly cookie is backend-origin scoped).
# Usually the same value as BACKEND_BASE_URL. Origin must be in the backend's
# EXTERNAL_ORIGIN_ALLOWLIST or CORS will 403.
NEXT_PUBLIC_BACKEND_BASE_URL=
NEXT_PUBLIC_BACKEND_CLIENT_ID=ainspace
# Workspace UUID ainspace is bound to (backend CLIENT_WORKSPACE_MAP value).
# Required: BFF injects it into /dm and /agents calls. Empty = thread APIs 500.
BACKEND_WORKSPACE_ID=

# Exhibition kiosk (EPIC18) — set only on the kiosk project, empty elsewhere.
# Its presence is the single switch for kiosk mode: the BFF auto-logs-in the
# shared service account and the client bootstraps a wallet-less session.
BACKEND_KIOSK_PRIVATE_KEY=   # server-only EOA key, signs challenge locally